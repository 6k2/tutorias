rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    function conversationPath(conversationId) {
      return /databases/$(database)/documents/conversations/$(conversationId);
    }

    function authInConversation(conversationId) {
      return isSignedIn()
        && exists(conversationPath(conversationId))
        && get(conversationPath(conversationId)).data.participantUids.hasAny([request.auth.uid]);
    }

    function authUidInConversationId(conversationId) {
      return isSignedIn()
        && conversationId.matches('.*' + request.auth.uid + '.*');
    }

    function reservationPath(reservationId) {
      return /databases/$(database)/documents/reservations/$(reservationId);
    }

    function reservationExists(reservationId) {
      return reservationId is string
        && reservationId.size() > 0
        && exists(reservationPath(reservationId));
    }

    function reservationData(reservationId) {
      return get(reservationPath(reservationId)).data;
    }

    function authOwnsReservation(reservationId) {
      return isSignedIn()
        && reservationExists(reservationId)
        && reservationData(reservationId).teacherId == request.auth.uid;
    }

    function authInReservation(reservationId) {
      return isSignedIn()
        && reservationExists(reservationId)
        && (
          reservationData(reservationId).teacherId == request.auth.uid
          || reservationData(reservationId).studentId == request.auth.uid
        );
    }

    function materialPath(materialId) {
      return /databases/$(database)/documents/tutoringMaterials/$(materialId);
    }

    function materialExists(materialId) {
      return exists(materialPath(materialId));
    }

    function materialData(materialId) {
      return get(materialPath(materialId)).data;
    }

    function offerPath(offerId) {
      return /databases/$(database)/documents/offers/$(offerId);
    }

    function offerExists(offerId) {
      return offerId is string
        && offerId.size() > 0
        && exists(offerPath(offerId));
    }

    function offerData(offerId) {
      return get(offerPath(offerId)).data;
    }

    function isOwnUserDoc(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function immutableConversationFields() {
      return request.resource.data.conversationKey == resource.data.conversationKey
        && request.resource.data.participantUids == resource.data.participantUids
        && request.resource.data.createdAt == resource.data.createdAt
        && request.resource.data.subjectKey == resource.data.subjectKey
        && request.resource.data.subjectName == resource.data.subjectName
        && request.resource.data.reservationId == resource.data.reservationId;
    }

    function conversationFieldsOnly() {
      return request.resource.data.keys().hasOnly([
        'conversationKey',
        'participantUids',
        'participantProfiles',
        'createdAt',
        'updatedAt',
        'lastMessage',
        'lastMessageAt',
        'unreadBy',
        'lastMessageMeta',
        'subjectKey',
        'subjectName',
        'reservationId'
      ]);
    }

    function validMessagePreviewUpdate() {
      return request.resource.data.diff(resource.data).affectedKeys().hasOnly([
          'lastMessage',
          'lastMessageAt',
          'updatedAt',
          'unreadBy',
          'lastMessageMeta'
        ])
        && request.resource.data.lastMessageAt == request.time
        && request.resource.data.updatedAt == request.time;
    }

    function validReadReceiptUpdate() {
      return request.resource.data.diff(resource.data).affectedKeys().hasOnly(['unreadBy'])
        && request.auth.uid in resource.data.unreadBy
        && !(request.auth.uid in request.resource.data.unreadBy);
    }

    function validConversationProfileUpdate() {
      return request.resource.data.diff(resource.data).affectedKeys().hasOnly([
          'participantProfiles',
          'participantUids',
          'subjectKey',
          'subjectName',
          'reservationId'
        ])
        && request.resource.data.conversationKey == resource.data.conversationKey
        && request.resource.data.createdAt == resource.data.createdAt
        && request.resource.data.participantUids.hasAny([request.auth.uid]);
    }

    function validMessageCreate(conversationId) {
      return request.resource.data.from == request.auth.uid
        && request.resource.data.conversationId == conversationId
        && request.resource.data.createdAt == request.time
        && request.resource.data.keys().hasOnly([
          'conversationId',
          'clientId',
          'from',
          'to',
          'text',
          'attachments',
          'attachmentURL',
          'attachmentType',
          'senderName',
          'createdAt',
          'localCreatedAt',
          'notified'
        ]);
    }

    function validOfferCreate() {
      return request.resource.data.uid == request.auth.uid
        && request.resource.data.createdAt == request.time
        && request.resource.data.updatedAt == request.time
        && request.resource.data.keys().hasOnly([
          'uid',
          'username',
          'subject',
          'subjectName',
          'maxStudents',
          'price',
          'images',
          'schedule',
          'enrolledCount',
          'pendingCount',
          'createdAt',
          'updatedAt'
        ]);
    }

    function validOfferOwnerUpdate() {
      return resource.data.uid == request.auth.uid
        && request.resource.data.uid == resource.data.uid
        && request.resource.data.createdAt == resource.data.createdAt
        && request.resource.data.updatedAt == request.time;
    }

    function validStudentPendingIncrement() {
      return request.resource.data.diff(resource.data).affectedKeys().hasOnly(['pendingCount', 'updatedAt'])
        && request.resource.data.pendingCount == currentPendingCount() + 1
        && request.resource.data.updatedAt == request.time
        && resource.data.uid != request.auth.uid;
    }

    function currentPendingCount() {
      return resource.data.keys().hasAny(['pendingCount'])
        ? resource.data.pendingCount
        : 0;
    }

    function currentEnrolledCount() {
      return resource.data.keys().hasAny(['enrolledCount'])
        ? resource.data.enrolledCount
        : 0;
    }

    function validOfferReservationStatusCounters() {
      return resource.data.uid == request.auth.uid
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
          'pendingCount',
          'enrolledCount',
          'updatedAt'
        ])
        && request.resource.data.pendingCount >= 0
        && request.resource.data.enrolledCount >= 0
        && request.resource.data.updatedAt == request.time
        && (
          (
            request.resource.data.pendingCount == currentPendingCount() - 1
            && request.resource.data.enrolledCount == currentEnrolledCount() + 1
          )
          || (
            request.resource.data.pendingCount == currentPendingCount()
            && request.resource.data.enrolledCount == currentEnrolledCount()
          )
          || (
            request.resource.data.pendingCount == currentPendingCount()
            && request.resource.data.enrolledCount == currentEnrolledCount() - 1
          )
          || (
            request.resource.data.pendingCount == currentPendingCount() - 1
            && request.resource.data.enrolledCount == currentEnrolledCount()
          )
        );
    }

    function validReservationCreate() {
      return request.resource.data.studentId == request.auth.uid
        && offerExists(request.resource.data.offerId)
        && request.resource.data.teacherId == offerData(request.resource.data.offerId).uid
        && request.resource.data.status == 'pending'
        && request.resource.data.createdAt == request.time
        && request.resource.data.updatedAt == request.time
        && request.resource.data.keys().hasOnly([
          'offerId',
          'subjectKey',
          'subjectName',
          'teacherId',
          'studentId',
          'status',
          'slot',
          'price',
          'studentDisplayName',
          'teacherDisplayName',
          'createdAt',
          'updatedAt'
        ]);
    }

    function authOwnsReservationDoc() {
      return isSignedIn()
        && (resource.data.teacherId == request.auth.uid || resource.data.studentId == request.auth.uid);
    }

    function validReservationStatusUpdate() {
      return resource.data.teacherId == request.auth.uid
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['status', 'updatedAt'])
        && request.resource.data.updatedAt == request.time
        && request.resource.data.status in ['pending', 'confirmed', 'rejected', 'cancelled'];
    }

    match /users/{userId} {
      allow get, list: if isSignedIn();
      allow create: if isOwnUserDoc(userId)
        && request.resource.data.uid == userId;
      allow update: if isOwnUserDoc(userId)
        && request.resource.data.uid == resource.data.uid;
      allow delete: if false;

      match /offers/{subjectId} {
        allow read, write: if isOwnUserDoc(userId);
      }

      match /materialViews/{materialId} {
        allow read: if isOwnUserDoc(userId);
        allow write: if isOwnUserDoc(userId)
          && request.resource.data.keys().hasOnly([
            'materialId',
            'reservationId',
            'lastViewedAt'
          ]);
      }
    }

    match /offers/{offerId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && validOfferCreate();
      allow update: if isSignedIn()
        && (
          validOfferOwnerUpdate()
          || validStudentPendingIncrement()
          || validOfferReservationStatusCounters()
        );
      allow delete: if false;
    }

    match /reservations/{reservationId} {
      allow read: if authOwnsReservationDoc()
        || (isSignedIn() && resource.data.status == 'confirmed');
      allow create: if isSignedIn() && validReservationCreate();
      allow update: if isSignedIn() && validReservationStatusUpdate();
      allow delete: if false;
    }

    match /conversations/{conversationId} {
      allow create: if isSignedIn()
        && request.resource.data.participantUids.size() == 2
        && request.resource.data.participantUids.hasAny([request.auth.uid])
        && conversationId == request.resource.data.conversationKey
        && request.resource.data.keys().hasOnly([
          'conversationKey',
          'participantUids',
          'participantProfiles',
          'createdAt',
          'updatedAt',
          'lastMessage',
          'lastMessageAt',
          'lastMessageMeta',
          'unreadBy',
          'subjectKey',
          'subjectName',
          'reservationId'
        ])
        && request.resource.data.conversationKey ==
          (request.resource.data.participantUids[0] < request.resource.data.participantUids[1]
            ? request.resource.data.participantUids[0] + '_' + request.resource.data.participantUids[1]
            : request.resource.data.participantUids[1] + '_' + request.resource.data.participantUids[0])
        && request.resource.data.createdAt == request.time
        && request.resource.data.updatedAt == request.time;

      allow get: if authInConversation(conversationId)
        || authUidInConversationId(conversationId);
      allow list: if authInConversation(conversationId);

      allow update: if authInConversation(conversationId)
        && conversationFieldsOnly()
        && (
          (
            immutableConversationFields()
            && (
              validMessagePreviewUpdate()
              || validReadReceiptUpdate()
            )
          )
          || validConversationProfileUpdate()
        );

      allow delete: if false;
    }

    match /conversations/{conversationId}/participants/{participantId} {
      allow read: if (isSignedIn() && resource.data.uid == request.auth.uid)
        || authInConversation(conversationId);
      allow create: if authInConversation(conversationId)
        && request.resource.data.uid in get(conversationPath(conversationId)).data.participantUids
        && request.resource.data.conversationId == conversationId;
      allow update, delete: if authInConversation(conversationId);
    }

    match /{path=**}/participants/{participantId} {
      allow read: if isSignedIn()
        && resource.data.uid == request.auth.uid;
    }

    match /conversations/{conversationId}/messages/{messageId} {
      allow read: if authInConversation(conversationId);
      allow create: if authInConversation(conversationId)
        && validMessageCreate(conversationId);
      allow update, delete: if false;
    }

    match /tutoringMaterials/{materialId} {
      function requestReservationId() {
        return request.resource.data.reservationId;
      }

      function validMaterialFields(data) {
        return data.keys().hasOnly([
          'reservationId',
          'subjectKey',
          'teacherId',
          'studentId',
          'title',
          'description',
          'storagePath',
          'fileName',
          'mimeType',
          'sizeBytes',
          'createdAt',
          'updatedAt',
          'offlineReady',
          'md5'
        ]);
      }

      allow get, list: if isSignedIn()
        && (
          resource.data.teacherId == request.auth.uid
          || resource.data.studentId == request.auth.uid
        );

      allow create: if isSignedIn()
        && reservationExists(requestReservationId())
        && authOwnsReservation(requestReservationId())
        && validMaterialFields(request.resource.data)
        && request.resource.data.teacherId == reservationData(requestReservationId()).teacherId
        && request.resource.data.studentId == reservationData(requestReservationId()).studentId
        && request.resource.data.subjectKey == reservationData(requestReservationId()).subjectKey
        && request.resource.data.storagePath.matches('^materials/' + requestReservationId() + '/[A-Za-z0-9._\\-]+$')
        && request.resource.data.fileName.matches('^[A-Za-z0-9._\\-]{3,}$')
        && request.resource.data.md5.matches('^[A-Fa-f0-9]{32}$')
        && request.resource.data.mimeType is string
        && request.resource.data.title is string
        && request.resource.data.title.size() > 0
        && request.resource.data.title.size() <= 140
        && (!request.resource.data.description || request.resource.data.description is string)
        && (!request.resource.data.description || request.resource.data.description.size() <= 600)
        && request.resource.data.subjectKey is string
        && request.resource.data.teacherId is string
        && request.resource.data.studentId is string
        && request.resource.data.sizeBytes is int
        && request.resource.data.sizeBytes <= 25 * 1024 * 1024
        && request.resource.data.offlineReady is bool
        && request.resource.data.createdAt == request.time
        && request.resource.data.updatedAt == request.time;

      allow update: if materialExists(materialId)
        && resource.data.teacherId == request.auth.uid
        && request.resource.data.reservationId == resource.data.reservationId
        && request.resource.data.teacherId == resource.data.teacherId
        && request.resource.data.studentId == resource.data.studentId
        && request.resource.data.subjectKey == resource.data.subjectKey
        && request.resource.data.storagePath == resource.data.storagePath
        && request.resource.data.fileName == resource.data.fileName
        && request.resource.data.mimeType == resource.data.mimeType
        && request.resource.data.sizeBytes == resource.data.sizeBytes
        && request.resource.data.md5 == resource.data.md5
        && request.resource.data.createdAt == resource.data.createdAt
        && request.resource.data.keys().hasOnly([
          'reservationId',
          'subjectKey',
          'teacherId',
          'studentId',
          'title',
          'description',
          'storagePath',
          'fileName',
          'mimeType',
          'sizeBytes',
          'createdAt',
          'updatedAt',
          'offlineReady',
          'md5'
        ])
        && request.resource.data.title is string
        && request.resource.data.title.size() > 0
        && request.resource.data.title.size() <= 140
        && (!request.resource.data.description || request.resource.data.description is string)
        && (!request.resource.data.description || request.resource.data.description.size() <= 600)
        && request.resource.data.offlineReady is bool
        && request.resource.data.updatedAt == request.time;

      allow delete: if materialExists(materialId)
        && resource.data.teacherId == request.auth.uid;
    }

    match /tutoringMaterials/{materialId}/attachments/{attachmentId} {
      allow get, list: if materialExists(materialId)
        && authInReservation(materialData(materialId).reservationId);

      allow create: if materialExists(materialId)
        && materialData(materialId).teacherId == request.auth.uid
        && request.resource.data.keys().hasOnly([
          'chunkIndex',
          'downloadUrl',
          'createdAt',
          'updatedAt'
        ])
        && request.resource.data.chunkIndex is int
        && request.resource.data.chunkIndex >= 0
        && request.resource.data.downloadUrl is string
        && request.resource.data.downloadUrl.matches('^https://')
        && request.resource.data.createdAt == request.time
        && request.resource.data.updatedAt == request.time;

      allow update: if materialExists(materialId)
        && materialData(materialId).teacherId == request.auth.uid
        && request.resource.data.chunkIndex == resource.data.chunkIndex
        && request.resource.data.downloadUrl == resource.data.downloadUrl
        && request.resource.data.createdAt == resource.data.createdAt
        && request.resource.data.keys().hasOnly([
          'chunkIndex',
          'downloadUrl',
          'createdAt',
          'updatedAt'
        ])
        && request.resource.data.updatedAt == request.time;

      allow delete: if materialExists(materialId)
        && materialData(materialId).teacherId == request.auth.uid;
    }
  }
}
